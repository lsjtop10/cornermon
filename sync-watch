#!/bin/bash

REMOTE_USER="lsjtop10"
REMOTE_IP="100.101.91.104"

LOCAL_DIR="."
REMOTE_DIR="~/projects/cornermon-clone"

# Flutter/Xcode가 머신별로 생성하는 파일은 Mac mini에서 다시 만들어야 한다.
# 이를 동기화하면 iOS Swift Package Manager가 Linux의 ephemeral 경로를 참조해
# 패키지를 찾지 못할 수 있다. --delete와 함께 써도 exclude 대상은 원격에서 지우지 않는다.
RSYNC_EXCLUDES=(
    --exclude='frontend/.dart_tool/'
    --exclude='frontend/build/'
    --exclude='frontend/ios/Flutter/ephemeral/'
    --exclude='frontend/ios/Pods/'
    --exclude='frontend/ios/.symlinks/'
    --exclude='frontend/ios/Flutter/Generated.xcconfig'
    --exclude='frontend/ios/Flutter/flutter_export_environment.sh'
    --exclude='frontend/android/local.properties'
    --exclude='frontend/.flutter-plugins-dependencies'
)

# 제외 대상 변경은 동기화를 다시 시작할 필요도 없으므로 감시에서 함께 제외한다.
WATCH_EXCLUDE='(^|/)frontend/(\.dart_tool|build|\.flutter-plugins-dependencies|ios/Flutter/ephemeral|ios/Pods|ios/\.symlinks|ios/Flutter/Generated\.xcconfig|ios/Flutter/flutter_export_environment\.sh|android/local\.properties)(/|$)'

# 스크립트 실행 시 비밀번호 입력받음
read -sp "SSH Password: " REMOTE_PASS
echo ""

# 동기화 명령 함수화
sync_files() {
    sshpass -p "$REMOTE_PASS" rsync -avz --delete \
        "${RSYNC_EXCLUDES[@]}" \
        -e ssh "$LOCAL_DIR" "${REMOTE_USER}@${REMOTE_IP}:${REMOTE_DIR}"
}

# 1. 최초 1회 즉시 동기화
echo "==> Initial sync starting..."
sync_files

# 2. 변경 사항 감지 및 실시간 동기화
echo "==> Watching for file changes..."
inotifywait -mrq -e modify,create,delete,move --exclude "$WATCH_EXCLUDE" "$LOCAL_DIR" | while read -r line; do
    echo "==> Change detected: $line"
    sync_files
done
